# =============================================
# RM3 RAG Chatbot — Backend Environment Config
# =============================================
# Copy this file to .env and fill in real values.

# Database
DATABASE_URL="postgresql://admin:password123@localhost:5432/rm3_rag?schema=public"

# Rate Limiting & Cache (Global Fallback)
THROTTLE_USER_LIMIT=30
THROTTLE_TENANT_LIMIT=200
THROTTLE_TTL_MS=60000
CACHE_TTL_MS=300000

# LLM Defaults (Global Fallback — overridden per tenant via TENANT_CONFIG)
DEFAULT_LLM_PROVIDER="openai"
DEFAULT_LLM_MODEL="gpt-4o-mini"
DEFAULT_LLM_TEMPERATURE="0.2"
DEFAULT_MAX_CONTEXT_TOKENS="4000"

# File Upload Limit (MB)
MAX_UPLOAD_MB=10

# LLM Provider API Keys (fill in your own)
OPENAI_API_KEY="sk-your-openai-key-here"
# GOOGLE_API_KEY="your-google-api-key-here"

# JWT (MVP only — temporary dev key, NOT for production)
JWT_SECRET="change_this_to_a_secure_random_string"
